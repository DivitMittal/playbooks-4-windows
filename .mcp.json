{
  "mcpServers": {
    "ansible": {
      "type": "stdio",
      "command": "pnpm",
      "args": ["dlx", "@ansible/ansible-mcp-server", "--stdio"],
      "env": {
        "WORKSPACE_ROOT": "~/Projects/playbooks-4-windows"
      }
    },
    "serena": {
      "type": "stdio",
      "command": "uvx",
      "args": [
        "--from",
        "git+https://github.com/oraios/serena",
        "serena",
        "start-mcp-server",
        "--context",
        "claude-code",
        "--project",
        "~/Projects/playbooks-4-windows/"
      ]
    }
  }
}
